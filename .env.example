# Your Discord server (guild) ID — only this server can use the bot
ALLOWED_GUILD_ID=your_server_id_here

# Discord bot token from https://discord.com/developers
DISCORD_TOKEN=your_discord_bot_token_here

# Role ID that can use the bot (admins always allowed). Leave empty for public access.
# DRIVE_BOT_ROLE_ID=123456789012345678
